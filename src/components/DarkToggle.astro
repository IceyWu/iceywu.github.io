<script>
  import SetSvgAnimation from "svg-animate-web";

  const btn = document.getElementById("dark-toggle");

  // 给当前可见的日/月图标应用手绘描边动画（保留路径原色）
  function animateToggleIcon() {
    const isDark = document.documentElement.classList.contains("dark");
    const svg = document.getElementById(isDark ? "moon-icon" : "sun-icon");
    if (!svg) return;
    const color = isDark ? "#fff" : "#333";
    SetSvgAnimation(svg as unknown as HTMLElement, {
      duration: 1,
      count: 1,
      fill: "transparent",
      stroke: color,
      strokeWidth: 7,
      renderMode: "fill",
      pathOptions: { stroke: color, strokeWidth: 1 },
    });
  }

  function applyToggle() {
    const root = document.documentElement;
    const willBeDark = !root.classList.contains("dark");
    root.classList.toggle("dark", willBeDark);
    localStorage.setItem("theme", willBeDark ? "dark" : "light");
    document.dispatchEvent(new CustomEvent("theme-change"));
  }

  function onClick(event: MouseEvent) {
    const supportsVT =
      typeof (document as any).startViewTransition === "function" &&
      !window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (!supportsVT) {
      applyToggle();
      return;
    }

    const x = event.clientX;
    const y = event.clientY;
    const endRadius = Math.hypot(
      Math.max(x, innerWidth - x),
      Math.max(y, innerHeight - y)
    );

    const willBeDark = !document.documentElement.classList.contains("dark");
    const transition = (document as any).startViewTransition(() => applyToggle());

    transition.ready.then(() => {
      const clipPath = [
        `circle(0px at ${x}px ${y}px)`,
        `circle(${endRadius}px at ${x}px ${y}px)`,
      ];
      document.documentElement.animate(
        { clipPath: willBeDark ? clipPath : [...clipPath].reverse() },
        {
          duration: 400,
          easing: "ease-out",
          pseudoElement: willBeDark
            ? "::view-transition-new(root)"
            : "::view-transition-old(root)",
        }
      );
    });
  }

  btn?.addEventListener("click", onClick);

  // 初始绘制 + 切换时重绘当前可见图标
  animateToggleIcon();
  document.addEventListener("theme-change", () =>
    requestAnimationFrame(animateToggleIcon)
  );
</script>
