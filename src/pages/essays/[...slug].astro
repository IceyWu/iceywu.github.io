---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import DarkToggle from "../../components/DarkToggle.astro";
import "../../styles/prose.css";

export async function getStaticPaths() {
  const essays = await getCollection("essays");
  return essays.map((essay) => ({
    params: { slug: essay.id },
    props: { essay },
  }));
}

const { essay } = Astro.props;
const { Content, headings } = await render(essay);

const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);

const fmtDate = essay.data.date.toLocaleDateString("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout title={`${essay.data.title} | IceyWu`} description={essay.data.description} type="article" publishedAt={essay.data.date.toISOString()}>
  <!-- 顶部工具栏 -->
  <div class="fixed top-4 right-4 z-50 flex items-center gap-4 rounded-full bg-white/60 px-4 py-2 shadow-sm ring-1 ring-black/5 backdrop-blur-lg md:top-6 md:right-6 dark:bg-black/60 dark:ring-white/10">
    <a href="/essays" title="返回随笔" class="font-sketch text-lg opacity-50 transition-opacity hover:opacity-100">← Essays</a>
    <DarkToggle />
  </div>

  <div class="relative mx-auto max-w-3xl px-6 py-16 md:py-24">
    <article class="prose">
      <header class="not-prose mb-10">
        <div class="relative inline-block">
          <h1 class="font-sketch text-4xl leading-tight opacity-95 md:text-5xl">{essay.data.title}</h1>
          <svg class="rough-underline pointer-events-none absolute -bottom-2 left-0 h-3 w-full" aria-hidden="true"></svg>
        </div>
        <div class="mt-4 flex flex-wrap items-center gap-3 font-sketch text-sm opacity-50">
          <time>{fmtDate}</time>
          {essay.data.tags.map((tag) => (
            <span class="opacity-80">#{tag}</span>
          ))}
        </div>
      </header>

      <Content />
    </article>

    <!-- 手绘返回按钮 -->
    <a
      href="/essays"
      class="rough-box group relative mt-14 inline-block px-6 py-2.5 font-sketch text-lg opacity-80 transition-all hover:-translate-y-0.5 hover:opacity-100"
    >
      <svg class="rough-frame pointer-events-none absolute inset-0 h-full w-full" aria-hidden="true"></svg>
      <span class="relative">← Back to Essays</span>
    </a>
  </div>

  <!-- TOC 侧边目录（大屏） -->
  {
    toc.length > 0 && (
      <nav class="rough-box fixed top-32 right-8 hidden max-w-[13rem] px-5 py-4 opacity-80 transition-opacity hover:opacity-100 2xl:block">
        <svg class="rough-frame pointer-events-none absolute inset-0 h-full w-full" aria-hidden="true" />
        <p class="relative mb-2 font-sketch text-sm opacity-50">目录</p>
        <ul class="relative space-y-1.5 font-sketch text-sm">
          {toc.map((h) => (
            <li class={h.depth === 3 ? "pl-3" : ""}>
              <a href={`#${h.slug}`} class="opacity-60 transition-opacity hover:opacity-100">
                {h.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    )
  }
</Layout>

<script>
  import rough from "roughjs";

  function drawBox(box: HTMLElement) {
    const svg = box.querySelector<SVGSVGElement>(".rough-frame");
    if (!svg) return;
    const w = Math.round(box.clientWidth);
    const h = Math.round(box.clientHeight);
    if (!w || !h) return;
    svg.setAttribute("viewBox", `0 0 ${w} ${h}`);
    svg.innerHTML = "";
    const rc = rough.svg(svg);
    svg.appendChild(
      rc.rectangle(4, 4, w - 8, h - 8, {
        stroke: "currentColor",
        strokeWidth: 1.3,
        roughness: 2,
        bowing: 2,
        seed: 7,
      })
    );
  }

  function drawUnderline(el: SVGSVGElement) {
    const w = Math.round(el.clientWidth);
    const h = Math.round(el.clientHeight) || 12;
    if (!w) return;
    el.setAttribute("viewBox", `0 0 ${w} ${h}`);
    el.innerHTML = "";
    const rc = rough.svg(el);
    const y = Math.round(h / 2);
    el.appendChild(
      rc.line(2, y, w - 2, y, {
        stroke: "currentColor",
        strokeWidth: 1.6,
        roughness: 2.4,
        bowing: 3,
        seed: 11,
      })
    );
  }

  function init() {
    document.querySelectorAll<HTMLElement>(".rough-box").forEach((box) => {
      drawBox(box);
      new ResizeObserver(() => drawBox(box)).observe(box);
    });
    document.querySelectorAll<SVGSVGElement>(".rough-underline").forEach((el) => {
      drawUnderline(el);
      new ResizeObserver(() => drawUnderline(el)).observe(el);
    });
  }

  requestAnimationFrame(() => requestAnimationFrame(init));
</script>
