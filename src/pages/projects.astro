---
import Layout from "../layouts/Layout.astro";
import DarkToggle from "../components/DarkToggle.astro";
import { getProjectSections, getLanguageColor } from "../lib/projects";

const sections = await getProjectSections();
---

<Layout title="Projects | IceyWu" description="List of projects that I am proud of.">
  <div class="fixed top-4 right-4 z-50 flex items-center gap-4 rounded-full bg-white/60 px-4 py-2 shadow-sm ring-1 ring-black/5 backdrop-blur-lg md:top-6 md:right-6 dark:bg-black/60 dark:ring-white/10">
    <a href="/" class="font-sketch text-lg opacity-50 transition-opacity hover:opacity-100">← Home</a>
    <DarkToggle />
  </div>

  <div class="mx-auto max-w-4xl px-6 py-20 md:py-28">
    <!-- Header -->
    <header class="relative mb-16">
      <h1 class="font-sketch text-4xl opacity-90 md:text-5xl">Projects</h1>
      <svg class="rough-underline pointer-events-none absolute -bottom-2 left-0 h-3 w-48" aria-hidden="true"></svg>
      <p class="mt-5 font-sketch text-sm opacity-40 md:text-base">
        Open source work I'm proud of — tools, templates, and contributions.
      </p>
    </header>

    <!-- Section nav (horizontal pills) -->
    <nav class="mb-12 flex flex-wrap gap-2">
      {sections.map((section) => (
        <a
          href={`#${section.id}`}
          class="rounded-sm border border-dashed border-current/15 px-3 py-1.5 font-sketch text-sm opacity-40 transition-all hover:border-current/30 hover:opacity-80"
        >
          {section.title}
        </a>
      ))}
    </nav>

    <!-- Sections -->
    <div class="space-y-16">
      {sections.map((section) => (
        <section id={section.id} class="scroll-mt-24">
          <div class="relative mb-6">
            <h2 class="font-sketch text-xl opacity-70">{section.title}</h2>
            <svg class="absolute -bottom-2 left-0 h-[1px] w-full opacity-10" aria-hidden="true">
              <line x1="0" y1="0" x2="100%" y2="0" stroke="currentColor" stroke-width="1" stroke-dasharray="4 6" />
            </svg>
          </div>

          <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            {section.repos.map((repo) => (
              <a
                href={repo.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group relative block rounded-sm p-4 no-underline transition-all hover:bg-black/3 dark:hover:bg-white/3"
              >
                {/* Dashed border drawn by CSS */}
                <div class="absolute inset-0 rounded-sm border border-dashed border-current/8 transition-colors group-hover:border-current/20"></div>

                {repo.owner && (
                  <div class="relative mb-2 flex items-center gap-2 font-sketch text-xs opacity-50">
                    <img src={repo.owner.avatarUrl} alt={repo.owner.name} class="h-4 w-4 rounded-full" />
                    <span>{repo.owner.name}</span>
                  </div>
                )}

                <div class="relative flex items-start justify-between gap-2">
                  <h3 class="break-words font-sketch text-base opacity-80 transition-opacity group-hover:opacity-100">
                    {repo.name}
                  </h3>
                  {repo.badge && (
                    <span class="shrink-0 font-sketch text-[10px] opacity-30">
                      {repo.badge}
                    </span>
                  )}
                </div>

                {repo.description && (
                  <p class="relative mt-1.5 line-clamp-2 text-sm leading-relaxed opacity-40 group-hover:opacity-60">
                    {repo.description}
                  </p>
                )}

                <div class="relative mt-3 flex flex-wrap items-center gap-3 font-sketch text-xs opacity-35 group-hover:opacity-55">
                  {repo.language && (
                    <span class="flex items-center gap-1">
                      <span
                        class="inline-block h-2 w-2 rounded-full"
                        style={`background-color:${getLanguageColor(repo.language)}`}
                      ></span>
                      {repo.language}
                    </span>
                  )}
                  {repo.stars > 0 && (
                    <span class="flex items-center gap-1">
                      ★ {repo.stars}
                    </span>
                  )}
                  {repo.forks > 0 && (
                    <span class="flex items-center gap-1">
                      ⑂ {repo.forks}
                    </span>
                  )}
                </div>
              </a>
            ))}
          </div>
        </section>
      ))}

      {sections.length === 0 && (
        <p class="py-20 text-center font-sketch opacity-30">
          No projects loaded. Check your GitHub token configuration.
        </p>
      )}
    </div>
  </div>
</Layout>

<script>
  import rough from "roughjs";

  function drawUnderline(svg: SVGSVGElement, seed: number) {
    const w = Math.round(svg.clientWidth);
    const h = Math.round(svg.clientHeight) || 12;
    if (!w) return;
    svg.setAttribute("viewBox", `0 0 ${w} ${h}`);
    svg.innerHTML = "";
    const rc = rough.svg(svg);
    const y = Math.round(h / 2);
    svg.appendChild(
      rc.line(2, y, w - 2, y, {
        stroke: "currentColor",
        strokeWidth: 1.5,
        roughness: 2.4,
        bowing: 3,
        seed,
      })
    );
  }

  function init() {
    document.querySelectorAll<SVGSVGElement>(".rough-underline").forEach((svg, i) => {
      drawUnderline(svg, i + 42);
      new ResizeObserver(() => drawUnderline(svg, i + 42)).observe(svg);
    });
  }

  requestAnimationFrame(() => requestAnimationFrame(init));
</script>
