---
import Layout from "../layouts/Layout.astro";
import DarkToggle from "../components/DarkToggle.astro";
import { demos } from "../lib/demos";

function formatDate(date: string) {
  return new Date(date).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

<Layout title="Demos | IceyWu" description="Creative Experiments & Open Source Projects">
  <div class="fixed top-4 right-4 z-50 flex items-center gap-4 rounded-full bg-white/60 px-4 py-2 shadow-sm ring-1 ring-black/5 backdrop-blur-lg md:top-6 md:right-6 dark:bg-black/60 dark:ring-white/10">
    <a href="/" class="font-sketch text-lg opacity-50 transition-opacity hover:opacity-100">← Home</a>
    <DarkToggle />
  </div>

  <div class="mx-auto min-h-screen max-w-6xl px-4 py-16 sm:px-6">
    <!-- Header -->
    <header class="mb-12 text-center">
      <h1 class="flex items-center justify-center gap-3 text-4xl font-bold tracking-tight">
        <span>Demos</span>
        <span class="rounded-md bg-gray-900 px-3 py-1 font-mono text-base text-white dark:bg-gray-100 dark:text-gray-900">
          {demos.length}
        </span>
      </h1>
      <p class="mt-3 opacity-50">Creative Experiments & Open Source Projects</p>
    </header>

    <!-- Grid -->
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {demos.map((demo) => (
        <a
          href={demo.link}
          target="_blank"
          rel="noopener noreferrer"
          class="demo-card group block overflow-hidden rounded-2xl bg-white no-underline transition-all duration-300 hover:-translate-y-1 dark:bg-gray-900"
        >
          <!-- Cover -->
          <div class="relative m-2 overflow-hidden rounded-xl" style="aspect-ratio:16/10">
            <img
              src={demo.cover}
              alt={demo.title}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <!-- Hover overlay -->
            <div class="absolute inset-0 rounded-xl bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
            <div class="absolute bottom-3 left-3 flex translate-y-2 items-center gap-1.5 rounded-full bg-white/20 px-3 py-1.5 text-xs font-medium text-white opacity-0 backdrop-blur-md transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">
              <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                <polyline points="15 3 21 3 21 9" />
                <line x1="10" y1="14" x2="21" y2="3" />
              </svg>
              View
            </div>
          </div>

          <!-- Content -->
          <div class="px-4 pb-4 pt-2">
            <h3 class="text-sm font-bold">{demo.title}</h3>
            <p class="mt-1 line-clamp-2 text-xs leading-relaxed opacity-50">{demo.description}</p>
            <div class="mt-3 flex items-center gap-1.5 opacity-40">
              <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10" />
                <polyline points="12 6 12 12 16 14" />
              </svg>
              <span class="font-mono text-xs">{formatDate(demo.date)}</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>

<style>
  .demo-card {
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.04),
      0 4px 8px rgba(0, 0, 0, 0.04),
      0 8px 16px rgba(0, 0, 0, 0.04);
  }
  .demo-card:hover {
    box-shadow:
      0 4px 8px rgba(0, 0, 0, 0.08),
      0 8px 16px rgba(0, 0, 0, 0.08),
      0 16px 32px rgba(0, 0, 0, 0.08);
  }
  :global(.dark) .demo-card {
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.2),
      0 4px 8px rgba(0, 0, 0, 0.15);
  }
  :global(.dark) .demo-card:hover {
    box-shadow:
      0 4px 8px rgba(0, 0, 0, 0.3),
      0 8px 16px rgba(0, 0, 0, 0.25),
      0 16px 32px rgba(0, 0, 0, 0.2);
  }
</style>
