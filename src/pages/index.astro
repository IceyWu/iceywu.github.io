---
import Layout from "../layouts/Layout.astro";
import Logo from "../components/Logo.astro";
import DarkToggle from "../components/DarkToggle.astro";
import GithubIcon from "../components/GithubIcon.astro";
import TechStackBubble from "../components/TechStackBubble.astro";
import { getGithubStats } from "../lib/github";

const stats = await getGithubStats();

// 本地无 GitHub 数据时的预览回退，保证页面完整可见
const DEFAULT_LANGS: Record<string, number> = {
  TypeScript: 45,
  Vue: 22,
  JavaScript: 14,
  Rust: 7,
  Go: 5,
  Python: 4,
  Shell: 3,
};
const languageStats =
  Object.keys(stats.languageStats).length > 0
    ? stats.languageStats
    : DEFAULT_LANGS;

const avatar =
  stats.avatar || "https://avatars.githubusercontent.com/u/66096254?v=4";

const createdYear = stats.createdAt
  ? new Date(stats.createdAt).getFullYear()
  : 2020;
const codingYears = new Date().getFullYear() - createdYear;

const statsData = [
  { value: codingYears || 5, label: "YEARS" },
  { value: stats.repos || 50, label: "REPOS" },
  { value: stats.totalStars || 200, label: "STARS" },
];

const navLinks = [
  { to: "/posts", label: "Posts", title: "技术博客" },
  { to: "/essays", label: "Essays", title: "随笔" },
  { to: "/projects", label: "Projects", title: "开源项目" },
  { to: "/demos", label: "Demos", title: "产品展示" },
  { to: "/map", label: "Map", title: "旅行地图" },
  { to: "/friends", label: "Friends", title: "友情链接" },
];
---

<Layout>
  <div
    class="relative flex min-h-screen items-center justify-center py-8 md:py-0"
  >
    <div class="w-full max-w-6xl px-6 md:px-16">
      <div
        class="grid grid-cols-1 items-center gap-8 md:grid-cols-12 md:gap-12"
      >
        <!-- 左侧：名字 + 标语 + 介绍 -->
        <div class="order-2 md:order-1 md:col-span-5">
          <div class="group relative mb-3 md:mb-4">
            <Logo class="w-60 md:w-80" strokeWidth={8} />
            <svg class="rough-underline pointer-events-none absolute -bottom-1 left-0 h-4 w-full opacity-30" aria-hidden="true"></svg>
          </div>

          <div class="mb-2 md:mb-3">
            <p
              class="font-sketch text-2xl leading-tight opacity-80 md:text-4xl dark:opacity-95"
            >
              You<br />
              <span class="ml-4 inline-block md:ml-6">only</span><br />
              <span class="ml-8 inline-block md:ml-12">live</span><br />
              <span class="ml-12 inline-block md:ml-[4.5rem]">once</span>
            </p>
            <p
              class="mt-1.5 ml-12 font-sketch-cn text-xs opacity-30 md:mt-2 md:ml-[4.5rem] md:text-sm dark:opacity-60"
            >
              向阳而生
            </p>
          </div>

          <div class="relative mb-3 max-w-md md:mb-4">
            <svg
              class="absolute -left-6 top-0 h-5 w-5 opacity-[0.15] dark:opacity-30"
              viewBox="0 0 20 20"
            >
              <path d="M3 8 Q2 5, 5 4 Q8 5, 7 8 L3 15" stroke="currentColor" stroke-width="1" fill="none"></path>
              <path d="M12 8 Q11 5, 14 4 Q17 5, 16 8 L12 15" stroke="currentColor" stroke-width="1" fill="none"></path>
            </svg>
            <p
              class="mb-2 font-sketch text-sm leading-relaxed opacity-60 md:mb-2.5 md:text-base dark:opacity-85"
            >
              Full-Stack Developer &amp; Digital Artisan
            </p>
            <div
              class="space-y-2.5 font-sketch-cn text-sm leading-loose opacity-50 md:text-base dark:opacity-75"
            >
              <p>
                你好，我是
                <a
                  href="https://github.com/iceywu"
                  target="_blank"
                  rel="noopener"
                  title="访问我的 GitHub 主页"
                  class="group relative inline-flex items-center"
                >
                  <span
                    class="border-b border-dashed border-current opacity-80 transition-opacity group-hover:opacity-100"
                    >IceyWu</span
                  >
                  <svg class="ml-0.5 h-3 w-3 opacity-50 transition-opacity group-hover:opacity-90" viewBox="0 0 12 12" fill="none">
                    <path d="M3 3 L9 3 L9 9 M9 3 L3 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
                  </svg>
                </a>
                ，前端开发 / 全栈工程师，开源爱好者，徒步 &amp; 摄影爱好者，自然系生活践行者。
              </p>
              <p>
                业余 coding 开发
                <a
                  href="https://lpalette.cn"
                  target="_blank"
                  rel="noopener"
                  title="访问 Life Palette 官网"
                  class="group relative inline-flex items-center"
                >
                  <span
                    class="border-b border-dashed border-current opacity-80 transition-opacity group-hover:opacity-100"
                    >「Life Palette」</span
                  >
                  <svg class="ml-0.5 h-3 w-3 opacity-50 transition-opacity group-hover:opacity-90" viewBox="0 0 12 12" fill="none">
                    <path d="M3 3 L9 3 L9 9 M9 3 L3 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
                  </svg>
                </a>
                ，帮你留存每一段旅途足迹！微信小程序搜「拾色 life」即可体验，期待和你一起记录走过的风景～
              </p>
            </div>
          </div>

          <!-- 数据 -->
          <div class="relative flex gap-6 md:gap-8">
            <svg
              class="absolute -top-4 left-0 h-2 w-full opacity-10 dark:opacity-25"
              viewBox="0 0 300 8"
              preserveAspectRatio="none"
            >
              <path class="draw-path" d="M0 4 L100 4 M120 4 L200 4 M220 4 L300 4" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 3"></path>
            </svg>
            {
              statsData.map((stat) => (
                <div class="group relative">
                  <div class="font-sketch text-4xl leading-none opacity-90 transition-opacity group-hover:opacity-100 md:text-5xl">
                    {stat.value}
                  </div>
                  <div class="mt-1 font-sketch-cn text-xs opacity-30 dark:opacity-60">
                    {stat.label}
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <!-- 中间：头像区 + 技术栈 -->
        <div
          class="relative order-1 flex flex-col items-center gap-4 md:order-2 md:col-span-4 md:gap-6"
        >
          <svg class="absolute -top-4 -left-4 h-6 w-6 animate-pulse opacity-[0.15]" viewBox="0 0 24 24" style="animation-duration:3s">
            <path class="draw-path" d="M12 2 L14 10 L22 12 L14 14 L12 22 L10 14 L2 12 L10 10 Z" stroke="currentColor" stroke-width="1" fill="none"></path>
          </svg>
          <svg class="absolute -bottom-4 -right-4 h-5 w-5 animate-pulse opacity-[0.15]" viewBox="0 0 20 20" style="animation-duration:4s">
            <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1" fill="none"></circle>
            <circle cx="10" cy="10" r="4" stroke="currentColor" stroke-width="1" fill="none"></circle>
          </svg>

          <!-- 头像 -->
          <div class="group relative h-40 w-40 md:h-48 md:w-48">
            <svg class="rough-ellipse pointer-events-none absolute -inset-2 opacity-30 transition-opacity group-hover:opacity-50" aria-hidden="true"></svg>
            <img
              src={avatar}
              alt="IceyWu 头像"
              loading="eager"
              decoding="async"
              class="animate-shape h-40 w-40 object-cover transition-transform group-hover:scale-105 md:h-48 md:w-48"
              style="will-change:border-radius,transform"
            />
          </div>

          <!-- 技术栈星球 -->
          <TechStackBubble languageStats={languageStats} />
        </div>

        <!-- 右侧：导航 + 语录 + 联系方式 -->
        <div class="relative order-3 md:col-span-3">
          <nav
            class="mb-8 flex flex-wrap gap-4 md:mb-10 md:flex-col md:gap-0 md:space-y-4"
          >
            {
              navLinks.map((link) => (
                <a
                  href={link.to}
                  title={link.title}
                  class="group relative inline-block font-sketch text-xl opacity-30 transition-all hover:opacity-100 md:text-2xl md:hover:ml-2 dark:opacity-70"
                >
                  {link.label}
                  <svg class="rough-underline pointer-events-none absolute -bottom-1 left-0 h-2 w-full opacity-0 transition-opacity group-hover:opacity-70" aria-hidden="true"></svg>
                </a>
              ))
            }
          </nav>

          <div class="relative pt-4 md:pt-5">
            <svg
              class="absolute top-0 left-0 h-1 w-full opacity-10 dark:opacity-25"
              viewBox="0 0 200 4"
              preserveAspectRatio="none"
            >
              <path class="draw-path" d="M0 2 Q10 1, 20 2 T40 2 Q50 3, 60 2 T80 2 Q90 1, 100 2 T120 2 Q130 3, 140 2 T160 2 Q170 1, 180 2 T200 2" stroke="currentColor" stroke-width="0.5" fill="none"></path>
            </svg>
            <p
              class="font-sketch text-sm leading-relaxed opacity-50 transition-opacity hover:opacity-40 md:text-base dark:opacity-50 dark:hover:opacity-70"
              title="生命流经你，而非流向你"
            >
              La vie coule<br />à travers toi,<br />pas vers toi
            </p>
            <p
              class="mt-2 font-sketch-cn text-xs opacity-[0.15] md:text-sm dark:opacity-40"
              title="You Only Live Once - 人生只有一次"
            >
              YOLO
            </p>
          </div>

          <div class="mt-4 flex flex-col gap-1.5 md:mt-6">
            <a
              href="mailto:3128006406@qq.com"
              class="flex items-center gap-1.5 font-sketch text-xs opacity-25 transition-opacity hover:opacity-60 md:text-sm dark:opacity-50 dark:hover:opacity-80"
              title="发送邮件"
            >
              <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="5" width="18" height="14" rx="2"></rect>
                <path d="m3 7 9 6 9-6"></path>
              </svg>
              <span>3128006406@qq.com</span>
            </a>
            <span
              class="flex cursor-default items-center gap-1.5 font-sketch text-xs opacity-25 md:text-sm dark:opacity-50"
              title="微信号"
            >
              <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M8.5 4C4.9 4 2 6.5 2 9.6c0 1.7.9 3.2 2.3 4.2L3.5 16l2.4-1.3c.8.2 1.7.4 2.6.4h.5a5 5 0 0 1-.2-1.4c0-3 2.9-5.3 6.4-5.3h.6C15.2 5.9 12.1 4 8.5 4Zm-2.3 3.2a.9.9 0 1 1 0 1.8.9.9 0 0 1 0-1.8Zm4.6 0a.9.9 0 1 1 0 1.8.9.9 0 0 1 0-1.8Z"></path>
                <path d="M22 13.6c0-2.6-2.5-4.7-5.6-4.7s-5.7 2.1-5.7 4.7 2.6 4.7 5.7 4.7c.7 0 1.3-.1 2-.3l1.9 1-.5-1.7c1.3-.9 2.2-2.2 2.2-3.7Zm-7.4-1.2a.7.7 0 1 1 0-1.4.7.7 0 0 1 0 1.4Zm3.6 0a.7.7 0 1 1 0-1.4.7.7 0 0 1 0 1.4Z"></path>
              </svg>
              <span>restsun</span>
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- 右上角工具栏 -->
    <div
      class="fixed top-4 right-4 z-50 flex flex-col gap-3 md:top-6 md:right-6 md:gap-4"
    >
      <a
        href="https://github.com/iceywu"
        target="_blank"
        rel="noopener"
        title="访问我的 GitHub"
        class="opacity-90 transition-opacity hover:opacity-100"
      >
        <GithubIcon />
      </a>
      <DarkToggle />
    </div>
  </div>
</Layout>

<script>
  import rough from "roughjs";

  function drawUnderline(svg: SVGSVGElement, seed: number) {
    const w = Math.round(svg.clientWidth);
    const h = Math.round(svg.clientHeight) || 10;
    if (!w) return;
    svg.setAttribute("viewBox", `0 0 ${w} ${h}`);
    svg.innerHTML = "";
    const rc = rough.svg(svg);
    const y = Math.round(h / 2);
    svg.appendChild(
      rc.line(2, y, w - 2, y, {
        stroke: "currentColor",
        strokeWidth: 1.5,
        roughness: 2.4,
        bowing: 3,
        seed,
      })
    );
  }

  function drawEllipse(svg: SVGSVGElement, seed: number) {
    const w = Math.round(svg.clientWidth);
    const h = Math.round(svg.clientHeight);
    if (!w || !h) return;
    svg.setAttribute("viewBox", `0 0 ${w} ${h}`);
    svg.innerHTML = "";
    const rc = rough.svg(svg);
    svg.appendChild(
      rc.ellipse(w / 2, h / 2, w - 6, h - 6, {
        stroke: "currentColor",
        strokeWidth: 1.2,
        roughness: 1.8,
        bowing: 1.5,
        seed,
      })
    );
  }

  function init() {
    document.querySelectorAll<SVGSVGElement>(".rough-underline").forEach((svg, i) => {
      drawUnderline(svg, i + 1);
      new ResizeObserver(() => drawUnderline(svg, i + 1)).observe(svg);
    });
    document.querySelectorAll<SVGSVGElement>(".rough-ellipse").forEach((svg, i) => {
      drawEllipse(svg, i + 20);
      new ResizeObserver(() => drawEllipse(svg, i + 20)).observe(svg);
    });
  }

  requestAnimationFrame(() => requestAnimationFrame(init));
</script>
